#include <stdio.h>

struct Process {
    int id;
    int arrivalTime;
    int burstTime;
    int completionTime;
    int waitingTime;
    int turnaroundTime;
};

void calculateFCFS(struct Process p[], int n, int startTime) {
    int time = startTime;

    for (int i = 0; i < n; i++) {
        if (time < p[i].arrivalTime)
            time = p[i].arrivalTime;

        p[i].completionTime = time + p[i].burstTime;
        p[i].turnaroundTime = p[i].completionTime - p[i].arrivalTime;
        p[i].waitingTime = p[i].turnaroundTime - p[i].burstTime;

        time = p[i].completionTime;
    }
}

void display(struct Process p[], int n, char queueName[]) {
    printf("\n%s Queue:\n", queueName);
    printf("ID\tAT\tBT\tCT\tTAT\tWT\n");

    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].id,
               p[i].arrivalTime,
               p[i].burstTime,
               p[i].completionTime,
               p[i].turnaroundTime,
               p[i].waitingTime);
    }
}

int main() {
    int sysCount, userCount;

    printf("Enter number of System Processes: ");
    scanf("%d", &sysCount);

    struct Process sys[10];

    printf("Enter Arrival Time and Burst Time for System Processes:\n");
    for (int i = 0; i < sysCount; i++) {
        sys[i].id = i + 1;
        scanf("%d %d", &sys[i].arrivalTime, &sys[i].burstTime);
    }

    printf("Enter number of User Processes: ");
    scanf("%d", &userCount);

    struct Process user[10];

    printf("Enter Arrival Time and Burst Time for User Processes:\n");
    for (int i = 0; i < userCount; i++) {
        user[i].id = i + 1;
        scanf("%d %d", &user[i].arrivalTime, &user[i].burstTime);
    }

    struct Process temp;

    for (int i = 0; i < sysCount - 1; i++) {
        for (int j = i + 1; j < sysCount; j++) {
            if (sys[i].arrivalTime > sys[j].arrivalTime) {
                temp = sys[i];
                sys[i] = sys[j];
                sys[j] = temp;
            }
        }
    }

    for (int i = 0; i < userCount - 1; i++) {
        for (int j = i + 1; j < userCount; j++) {
            if (user[i].arrivalTime > user[j].arrivalTime) {
                temp = user[i];
                user[i] = user[j];
                user[j] = temp;
            }
        }
    }
    calculateFCFS(sys, sysCount, 0);


    int lastTime = sys[sysCount - 1].completionTime;


    calculateFCFS(user, userCount, lastTime);

    display(sys, sysCount, "System");
    display(user, userCount, "User");

    return 0;
}
